{
  "jobs": [
    {
      "name": "pipeline",
      "steps": [
        { "name": "checkout", "handler": "log", "args": ["checkout: fetching source"] },

        { "parallel": [
            { "name": "build-linux",   "handler": "sleep", "args": ["1s"] },
            { "name": "build-windows", "handler": "sleep", "args": ["1s"] },
            { "name": "build-mac",     "handler": "sleep", "args": ["1s"] }
        ]},

        { "name": "release", "handler": "log", "args": ["release: all platform builds done"] }
      ]
    }
  ]
}
