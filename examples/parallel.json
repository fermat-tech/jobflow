{
  "jobs": [
    {
      "name": "pipeline",
      "steps": [
        { "name": "checkout", "handler": "log", "args": ["checkout: fetching source"] },

        { "name": "build-linux",   "handler": "sleep", "args": ["1s"], "dependsOn": ["checkout"] },
        { "name": "build-windows", "handler": "sleep", "args": ["1s"], "dependsOn": ["checkout"] },
        { "name": "build-mac",     "handler": "sleep", "args": ["1s"], "dependsOn": ["checkout"] },

        { "name": "release", "handler": "log", "args": ["release: all platform builds done"],
          "dependsOn": ["build-linux", "build-windows", "build-mac"] }
      ]
    }
  ]
}
